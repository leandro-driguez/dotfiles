# Per-machine secrets and identity. Copy this to ~/.env.local and fill in:
#   cp env/.env.example ~/.env.local
#   chmod 600 ~/.env.local
#
# Sourced by:
#   - shell/.bashrc, shell/.zshrc        (interactive shells)
#   - scripts/render-templates.sh        (envsubst over *.tmpl files)
#
# NEVER commit ~/.env.local. It is gitignored, but verify with `git status`
# before pushing if you ever move it inside the repo by accident.

# --- Git identity (consumed by git/.gitconfig.tmpl) ---
GIT_USER_NAME=
GIT_USER_EMAIL=

# --- Service tokens (sourced into the shell) ---
SUPABASE_ACCESS_TOKEN=
